# Server port (Railway sets this automatically, keep 5000 for local)
PORT=5000

# MongoDB connection string
# Local:   mongodb://localhost:27017/applylog
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/applylog
MONGO_URI=mongodb://localhost:27017/applylog

# JWT secret — use any long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_key_here

# Allowed frontend origin for CORS
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173